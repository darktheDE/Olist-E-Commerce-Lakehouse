# Copy this file to .env and adjust values for your local machine.

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET_BRONZE=bronze
MINIO_BUCKET_SILVER=silver
MINIO_BUCKET_GOLD=gold

# Spark uses S3A protocol but authenticates against local MinIO above.
# No AWS account/key is required.

# PostgreSQL (Hive metastore backend for next issues)
POSTGRES_DB=metastore
POSTGRES_USER=metastore
POSTGRES_PASSWORD=metastore123

# Local static token for notebook login only
JUPYTER_TOKEN=lakehouse123

# Superset
SUPERSET_SECRET_KEY=generate_your_own_secret_here
SUPERSET_ADMIN=admin
SUPERSET_PASSWORD=admin
